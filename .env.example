# ═══════════════════════════════════════════════════════════════════════════════
# .env.example — Konfigurationsvorlage für das Homelab-Imperium
# ═══════════════════════════════════════════════════════════════════════════════
#
# ⚠  SICHERHEITSHINWEISE:
#   - Diese Datei ist eine VORLAGE ohne echte Geheimnisse.
#   - Kopiere sie nach ".env" und fülle DEINE eigenen Werte ein:
#       cp .env.example .env
#   - ".env" MUSS in der .gitignore stehen — NIEMALS committen!
#       echo ".env" >> .gitignore
#   - Setze restriktive Dateiberechtigungen:
#       chmod 600 .env
#   - Verwende für Passwörter einen Passwort-Manager (Empfehlung: Diceware mit 6+ Wörtern).
#   - API-Keys regelmäßig rotieren — siehe docs/security_hardening.md Abschnitt 9.3.2.
#
# ═══════════════════════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 1: Projekt-Metadaten & Betriebsmodus
# ──────────────────────────────────────────────────────────────────────────────

# Eindeutiger Name der Anwendung (wird in Logs und Health-Checks verwendet).
APP_NAME="Homelab-Imperium OS"

# Betriebsmodus der API — gültige Werte: "development" | "production".
#   development → Detaillierte Fehlermeldungen, Hot-Reload, Debug-Logging.
#   production  → Minimierte Fehler, keine Stack-Traces, striktes Logging.
API_ENV="development"

# Debug-Modus für die FastAPI-Applikation.
#   true  → Aktiviert --reload für Uvicorn, ausführliche Tracebacks.
#   false → Produktivbetrieb: keine Auto-Reloads, generische Fehlermeldungen.
DEBUG=true


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 2: PostgreSQL-Datenbank
# ──────────────────────────────────────────────────────────────────────────────

# Vollständige PostgreSQL-Verbindungs-URI für SQLAlchemy.
# Format: postgresql://<BENUTZER>:<PASSWORT>@<HOST>:<PORT>/<DATENBANK>
#   BENUTZER  → Datenbankbenutzer (muss in PostgreSQL existieren).
#   PASSWORT  → Starkes Passwort (min. 20 Zeichen, kein Wort aus dem Wörterbuch).
#   HOST      → Docker-Service-Name (postgres_db) oder localhost.
#   PORT      → PostgreSQL-Standardport innerhalb des Docker-Netzwerks.
#   DATENBANK → Name der Datenbank (muss vorher mit CREATE DATABASE angelegt sein).
DATABASE_URL="postgresql://homelab_user:DEIN_STARKES_PASSWORT_HIER@postgres_db:5432/homelab_imperium"

# Alternative Einzelparameter (werden von config.py zur URI zusammengesetzt):
# DB_HOST=postgres_db
# DB_PORT=5432
# DB_NAME=homelab_imperium
# DB_USER=homelab_user
# DB_PASS=DEIN_STARKES_PASSWORT_HIER

# Maximale Anzahl paralleler Verbindungen im SQLAlchemy-Connection-Pool.
# Empfehlung: 10-20 für ein Homelab, abhängig von der RAM-Ausstattung.
DB_POOL_SIZE=10

# Maximaler Überlauf des Connection-Pools (Spitzenlast-Puffer).
DB_MAX_OVERFLOW=20

# Timeout in Sekunden für inaktive Datenbank-Verbindungen.
DB_POOL_TIMEOUT=30


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 3: ChromaDB — Vektordatenbank für RAG
# ──────────────────────────────────────────────────────────────────────────────

# HTTP-Endpunkt der ChromaDB-Instanz.
#   Entwicklung:  http://localhost:8000
#   Docker:       http://chromadb:8000  (Service-Name aus docker-compose.yml)
CHROMADB_ENDPOINT="http://chromadb:8000"

# Persistenzpfad für ChromaDB-Daten innerhalb des Containers.
# Der Pfad wird via Docker-Volume auf /mnt/data/db/chroma gemountet.
CHROMADB_PERSIST_DIRECTORY="/chroma/data"

# Standard-Embedding-Modell für die Vektorisierung von PDF-Dokumenten.
# Genutzt von nomic-embed-text via Ollama. Alternatives Modell: all-MiniLM-L6-v2.
CHROMADB_EMBEDDING_MODEL="nomic-embed-text"

# Dimension der Embedding-Vektoren (muss mit dem gewählten Modell übereinstimmen).
# nomic-embed-text → 768 Dimensionen.
CHROMADB_EMBEDDING_DIMENSION=768

# Standard-Top-K für semantische Ähnlichkeitssuche (RAG-Kontextabruf).
CHROMADB_DEFAULT_TOP_K=4


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 4: Jellyfin — Medienserver-Integration
# ──────────────────────────────────────────────────────────────────────────────

# Jellyfin-API-Schlüssel für die REST-Authentifizierung.
# ERSTELLUNG: Jellyfin Admin Dashboard → API Keys → Neuer Schlüssel.
# ⚠ Dieser Schlüssel gewährt VOLLEN Zugriff auf die Jellyfin-API.
# ⚠ Bei Kompromittierung: SOFORT in der Jellyfin-Admin-Oberfläche rotieren.
JELLYFIN_API_KEY="DEIN_JELLYFIN_API_KEY_HIER"

# Basis-URL der Jellyfin-Instanz.
#   Docker:  http://jellyfin:8096
#   Lokal:   http://localhost:8096
JELLYFIN_BASE_URL="http://jellyfin:8096"

# Timeout in Sekunden für Jellyfin-API-Requests.
JELLYFIN_TIMEOUT=15

# Maximale Wiederholungsversuche bei fehlgeschlagenen Jellyfin-API-Calls.
JELLYFIN_MAX_RETRIES=3

# Standard-Benutzer-ID für die Medienbibliothek-Abfragen.
# Die User-ID findest du in der Jellyfin-Admin-Oberfläche unter "Benutzer".
JELLYFIN_DEFAULT_USER_ID="DEINE_JELLYFIN_USER_ID_HIER"


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 5: Ollama — Lokale LLM-Inferenz (CPU-Fallback auf dem HP-Server)
# ──────────────────────────────────────────────────────────────────────────────

# Endpunkt der lokalen Ollama-Instanz auf dem HP-Server (CPU-Inferenz).
#   Intern:  http://127.0.0.1:11434  oder  http://localhost:11434
#   Docker:  http://ollama:11434
OLLAMA_LOCAL_ENDPOINT="http://127.0.0.1:11434"

# Standard-LLM-Modell für die lokale CPU-Inferenz.
# Empfehlungen (nach RAM-Verfügbarkeit, HP-Server hat 16 GB):
#   qwen2.5-coder:1.5b   (1,1 GB) — Leichtgewichtig, Code-optimiert
#   qwen2.5-coder:3b     (2,0 GB) — Bessere Code-Qualität
#   llama3.2:1b          (0,8 GB) — Minimal, allgemein
#   llama3.2:3b          (2,0 GB) — Ausgewogen
#   llama3.1:8b          (4,7 GB) — Nur wenn RAM ausreicht
OLLAMA_LOCAL_DEFAULT_MODEL="qwen2.5-coder:3b"

# Timeout in Sekunden für lokale Ollama-Requests.
# CPU-Inferenz ist langsamer → höheres Timeout als GPU.
OLLAMA_LOCAL_TIMEOUT=120

# Maximale Token-Anzahl pro Generation (lokal).
OLLAMA_LOCAL_MAX_TOKENS=4096

# Temperatur für lokale Generierungen (0.0 = deterministisch, 1.0 = kreativ).
OLLAMA_LOCAL_TEMPERATURE=0.7


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 6: Ollama — Remote GPU-Desktop (Tailscale-Mesh, NVIDIA GTX 1060)
# ──────────────────────────────────────────────────────────────────────────────

# Endpunkt der Ollama-Instanz auf dem GPU-Desktop-PC.
#   Tailscale:  http://desktop-pc-tailscale:11434
#   Lokal/LAN:  http://desktop-pc:11434
#   IP-basiert: http://192.168.1.100:11434
OLLAMA_DESKTOP_ENDPOINT="http://desktop-pc-tailscale:11434"

# Standard-LLM-Modell für die GPU-beschleunigte Inferenz (GTX 1060 6 GB).
# Empfehlungen (nach VRAM, GTX 1060 hat 6 GB):
#   qwen2.5-coder:7b     (4,7 GB) — Passt in 6 GB VRAM, sehr gute Code-Qualität
#   llama3.1:8b          (4,7 GB) — Vielseitig, gute Deutsch-Kenntnisse
#   mistral:7b           (4,1 GB) — Ausgewogen, schnell
#   deepseek-coder:6.7b  (4,0 GB) — Spezialisiert auf Code
#   phi3:medium-4k       (4,9 GB) — Microsoft, gute Reasoning-Fähigkeiten
OLLAMA_DESKTOP_DEFAULT_MODEL="qwen2.5-coder:7b"

# Timeout in Sekunden für GPU-Desktop-Requests.
# GPU-Inferenz ist schneller → niedrigeres Timeout.
OLLAMA_DESKTOP_TIMEOUT=60

# Maximale Token-Anzahl pro Generation (GPU).
# GPU kann längere Kontexte effizienter verarbeiten.
OLLAMA_DESKTOP_MAX_TOKENS=8192

# Temperatur für GPU-Generierungen.
OLLAMA_DESKTOP_TEMPERATURE=0.7

# Ping-Intervall in Sekunden für die Erreichbarkeitsprüfung des GPU-Desktops.
OLLAMA_DESKTOP_PING_INTERVAL=30

# Maximale Anzahl aufeinanderfolgender fehlgeschlagener Ping-Versuche,
# bevor automatisch auf CPU-Fallback umgeschaltet wird.
OLLAMA_DESKTOP_MAX_PING_FAILURES=3


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 7: RAG-Engine — Retrieval-Augmented Generation
# ──────────────────────────────────────────────────────────────────────────────

# Chunk-Größe beim Zerteilen von PDF-Dokumenten (in Zeichen).
# Kleinere Chunks = präzisere Suche, weniger Kontext.
RAG_CHUNK_SIZE=512

# Überlappung zwischen aufeinanderfolgenden Chunks (in Zeichen).
# Verhindert, dass Sätze an Chunk-Grenzen abgeschnitten werden.
RAG_CHUNK_OVERLAP=100

# Standard-Name der ChromaDB-Collection für Schul-Skripte.
RAG_COLLECTION_SCHOOL="school_pdfs"

# Standard-Name der ChromaDB-Collection für IT-Fachbücher.
RAG_COLLECTION_IT="it_books"

# Maximal erlaubte PDF-Dateigröße für die Verarbeitung (in Megabytes).
RAG_MAX_PDF_SIZE_MB=50

# Pfad zum temporären Verzeichnis für die PDF-Verarbeitung.
RAG_TEMP_DIR="/tmp/rag_processing"


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 8: Pfade für persistente Speicherorte (HDD-Mount /mnt/data)
# ──────────────────────────────────────────────────────────────────────────────

# Wurzelverzeichnis für alle persistenten Daten auf dem Server.
# Produktion:  /mnt/data  (externe HDD, über fstab/crypttab gemountet)
# Entwicklung: ./data      (relativer Pfad innerhalb des Repositories)
DATA_ROOT="/mnt/data"

# Datenbank-Dateien (PostgreSQL-Tablespace, ChromaDB-Vektor-Indizes).
#   Produktion:  /mnt/data/db
#   Entwicklung: ./data/db
PATH_DB="/mnt/data/db"

# Medienbibliothek (Jellyfin-Filme, Serien, Musik-Dateien).
#   Produktion:  /mnt/data/media
#   Entwicklung: ./data/media
PATH_MEDIA="/mnt/data/media"

# Lokale KI-Modell-Artefakte und Ollama-Modell-Caches.
#   Produktion:  /mnt/data/ai_models
#   Entwicklung: ./data/ai_models
PATH_AI_MODELS="/mnt/data/ai_models"

# Benutzer-Dateien und Uploads (File-Bunker: Schul-PDFs, Dokumente, Backups).
#   Produktion:  /mnt/data/files
#   Entwicklung: ./data/files
PATH_FILES="/mnt/data/files"

# Automotive-Workbench: 3D-Modelle, OpenSCAD-Skripte, Berechnungsergebnisse.
#   Produktion:  /mnt/data/auto
#   Entwicklung: ./data/auto
PATH_AUTO="/mnt/data/auto"

# Caddy-Konfiguration und TLS-Zertifikate.
#   Produktion:  /mnt/data/caddy_data
#   Entwicklung: ./data/caddy_data
PATH_CADDY_DATA="/mnt/data/caddy_data"

# Caddy-Runtime-Konfiguration (automatisch generiert).
#   Produktion:  /mnt/data/caddy_config
#   Entwicklung: ./data/caddy_config
PATH_CADDY_CONFIG="/mnt/data/caddy_config"


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 9: code-server — Integrierte Web-IDE
# ──────────────────────────────────────────────────────────────────────────────

# Endpunkt des code-server-Containers (innerhalb des Docker-Netzwerks).
CODE_SERVER_ENDPOINT="http://code_server:8080"

# Pfad zum code-server-Projektverzeichnis (wird in den Container gemountet).
CODE_SERVER_PROJECT_DIR="/mnt/data/code_server_projects"

# Passwort-Hash für die code-server-Authentifizierung.
# Generierung:  echo -n "dein_passwort" | sha256sum | cut -d' ' -f1
CODE_SERVER_PASSWORD_HASH="DEIN_SHA256_PASSWORT_HASH_HIER"


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 10: Worker-Agent (Remote GPU-Desktop für CAD/OpenSCAD)
# ──────────────────────────────────────────────────────────────────────────────

# Endpunkt des Worker-Agenten auf dem GPU-Desktop (Tailscale-Mesh).
# Der Worker führt rechenintensive OpenSCAD-Renderings und CAD-Berechnungen aus.
WORKER_AGENT_ENDPOINT="http://desktop-pc-tailscale:9000"

# Timeout für Worker-Agent-Aufgaben (Renderings können lang dauern).
WORKER_AGENT_TIMEOUT=300

# Maximal erlaubte Modellgröße für OpenSCAD-Rendering (in Polygonen).
WORKER_AGENT_MAX_POLYGONS=1000000


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 11: Caddy — Reverse Proxy & TLS
# ──────────────────────────────────────────────────────────────────────────────

# Vollständiger Domain-Name (FQDN) für den Tailscale-MagicDNS-Eintrag.
# Wird von Caddy für die TLS-Zertifikatsanforderung verwendet.
CADDY_DOMAIN="hp-server.tailscale-mesh.net"

# E-Mail-Adresse für Let's Encrypt-Zertifikatsbenachrichtigungen.
#   Tailscale-interne Nutzung:  leer lassen (Tailscale stellt eigene Zertifikate)
#   Öffentliche Domains:        gültige E-Mail für Ablaufwarnungen
CADDY_ACME_EMAIL=""

# Rate-Limiting: Maximale Requests pro Minute pro Client-IP.
# Siehe Caddyfile für die genaue Konfiguration der rate_limit-Zone.
CADDY_RATE_LIMIT_RPM=100


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 12: Tailscale — Mesh-VPN
# ──────────────────────────────────────────────────────────────────────────────

# Tailscale-Auth-Key für unbeaufsichtigte Server-Authentifizierung.
# ERSTELLUNG: Tailscale Admin Console → Settings → Auth Keys → Generate Key.
# ⚠ Dieser Key ist EINMALIG verwendbar (es sei denn "reusable" explizit aktiviert).
# ⚠ Format: tskey-auth-xxxxxxxxxxxxxx
TAILSCALE_AUTH_KEY="DEIN_TAILSCALE_AUTH_KEY_HIER"

# Hostname des Servers innerhalb des Tailscale-Mesh-Netzwerks.
# Wird als --hostname an tailscale up übergeben.
TAILSCALE_HOSTNAME="hp-server"

# Tailscale-ACL-Tags für diesen Knoten (in der Admin Console definiert).
TAILSCALE_TAGS="tag:server"


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 13: Sandbox — Code-Ausführung
# ──────────────────────────────────────────────────────────────────────────────

# Timeout für isolierte Python-Code-Ausführung in der Sandbox (in Sekunden).
SANDBOX_EXECUTION_TIMEOUT=10

# Maximal erlaubte Ausgabegröße eines Sandbox-Prozesses (in Bytes).
# Verhindert, dass fehlerhafte Skripte das System mit Output fluten.
SANDBOX_MAX_OUTPUT_SIZE=1048576

# Maximal erlaubte Speichernutzung pro Sandbox-Prozess (in MB).
SANDBOX_MAX_MEMORY_MB=512

# Docker-Image für die isolierte Code-Ausführung.
SANDBOX_DOCKER_IMAGE="python:3.14-slim"


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 14: Logging & Monitoring
# ──────────────────────────────────────────────────────────────────────────────

# Log-Level für die FastAPI-Applikation.
# Gültige Werte: DEBUG | INFO | WARNING | ERROR | CRITICAL
#   development → DEBUG (ausführliche Ausgaben)
#   production  → WARNING (nur relevante Ereignisse)
LOG_LEVEL="DEBUG"

# Pfad zur Log-Datei (innerhalb des Containers).
LOG_FILE_PATH="/var/log/homelab_imperium/app.log"

# Maximale Größe einer einzelnen Log-Datei vor Rotation (in MB).
LOG_MAX_SIZE_MB=10

# Anzahl der aufbewahrten rotierten Log-Dateien.
LOG_BACKUP_COUNT=5

# Intervall in Sekunden für Systemmetrik-Erfassung (CPU, RAM, Disk).
MONITOR_INTERVAL_SECONDS=10


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 15: Container-Netzwerk & Ports
# ──────────────────────────────────────────────────────────────────────────────

# Docker-Netzwerkname für die interne Container-Kommunikation.
DOCKER_NETWORK_NAME="imperium_net"

# Interne Ports (nur innerhalb des Docker-Netzwerks, NICHT nach außen exponiert):
#   FastAPI : 8000
#   PostgreSQL : 5432
#   ChromaDB : 8000
#   Ollama (lokal) : 11434
#   Jellyfin : 8096
#   code-server : 8080
#   Worker-Agent : 9000

# Exponierte Ports auf dem Host (via Caddy):
#   80  → HTTP (nur Tailscale-Interface)
#   443 → HTTPS (nur Tailscale-Interface)
#   41641/udp → WireGuard/Tailscale (für direkte Verbindungen)


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 16: Feature-Flags & Experimentelle Einstellungen
# ──────────────────────────────────────────────────────────────────────────────

# Aktiviert den Power-Mode für GPU-beschleunigte Inferenz (Standard bei /ai/chat).
# Bei false wird immer die CPU genutzt, selbst wenn die GPU verfügbar ist.
FEATURE_POWER_MODE_DEFAULT=true

# Aktiviert RAG (Retrieval-Augmented Generation) standardmäßig bei KI-Anfragen.
FEATURE_RAG_ENABLED_DEFAULT=true

# Aktiviert Streaming-Responses für KI-Chats (Token-für-Token-Ausgabe).
FEATURE_STREAMING_RESPONSES=true

# Aktiviert die automatische Transcodierung in Jellyfin.
# Bei false wird nur Direct-Play verwendet (keine Transcodierung).
FEATURE_JELLYFIN_TRANSCODING=true

# Erlaubt Datei-Uploads via das Web-Interface.
FEATURE_FILE_UPLOAD_ENABLED=true

# Aktiviert CORS für lokale Entwicklung (nur in API_ENV="development" wirksam).
FEATURE_CORS_DEV_MODE=false

# Aktiviert den interaktiven 3D-SVG-Körper-Hologramm-Modus im Gesundheitsmodul.
FEATURE_HEALTH_HOLOGRAM=true


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 17: Backup & Wiederherstellung
# ──────────────────────────────────────────────────────────────────────────────

# Pfad für automatisierte Datenbank-Backups (PostgreSQL-Dumps).
BACKUP_DB_PATH="/mnt/data/backups/db"

# Pfad für automatisierte Dateisystem-Backups.
BACKUP_FILES_PATH="/mnt/data/backups/files"

# Intervall für automatisierte Backups (in Stunden).
BACKUP_INTERVAL_HOURS=24

# Anzahl der aufbewahrten Backup-Generationen.
BACKUP_RETENTION_COUNT=7


# ──────────────────────────────────────────────────────────────────────────────
# ABSCHNITT 18: E-Mail-Benachrichtigungen (optional, für Monitoring)
# ──────────────────────────────────────────────────────────────────────────────

# SMTP-Server für Systembenachrichtigungen (z. B. Backup-Status, Fehler).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=homelab-alerts@example.com
# SMTP_PASS=DEIN_SMTP_PASSWORT_HIER
# SMTP_USE_TLS=true

# Empfänger-Adresse für kritische Systemwarnungen.
# ALERT_EMAIL=admin@example.com


# ═══════════════════════════════════════════════════════════════════════════════
# SCHNELLEINSTIEG — .env ERSTELLEN
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. Kopiere diese Vorlage:
#      cp .env.example .env
#
# 2. Setze Dateiberechtigungen:
#      chmod 600 .env
#
# 3. Ersetze ALLE Platzhalter (DEIN_..., HIER, example.com) mit echten Werten.
#    Empfohlene Reihenfolge:
#      a) DATABASE_URL          → PostgreSQL-Passwort ändern
#      b) JELLYFIN_API_KEY      → Aus Jellyfin-Admin-UI holen
#      c) OLLAMA_*_ENDPOINT     → Korrekte Hostnames/IPs eintragen
#      d) TAILSCALE_AUTH_KEY    → Aus Tailscale-Admin-Konsole generieren
#      e) CODE_SERVER_PASSWORD_HASH → Mit sha256sum generieren
#      f) DATA_ROOT & PATH_*    → Falls nicht /mnt/data (Entwicklung: ./data)
#
# 4. Validiere die Konfiguration:
#      cd backend && python -c "from app.config import settings; print(settings)"
#
# 5. Starte die Anwendung:
#      docker-compose up -d
#
# ═══════════════════════════════════════════════════════════════════════════════